@{
    ViewData["Title"] = "Admin Dashboard";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<style>
    .dash-card {
        border: 1px solid rgba(0,0,0,.08);
        border-radius: 14px;
        box-shadow: 0 6px 18px rgba(0,0,0,.04);
        transition: transform .08s ease-in-out, box-shadow .08s ease-in-out;
        height: 100%;
    }

    .dash-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 10px 26px rgba(0,0,0,.07);
    }

    .dash-card .dash-icon {
        width: 44px;
        height: 44px;
        display: grid;
        place-items: center;
        border-radius: 12px;
        background: rgba(25, 135, 84, .12);
        color: #198754;
        font-size: 18px;
        margin-bottom: 12px;
    }

    .dash-muted {
        color: rgba(0,0,0,.62);
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <h3 class="mb-0">Admin Dashboard</h3>
        <div class="dash-muted">Quản lý nhanh danh mục, câu hỏi và kết quả kiểm tra.</div>
    </div>
</div>

<div class="row g-3">
    <div class="col-12 col-md-6 col-lg-4">
        <a class="text-decoration-none" href="/admin/cai-dat-danh-muc">
            <div class="card dash-card p-3">
                <div class="dash-icon"><i class="ti ti-list-details"></i></div>
                <div class="fw-semibold">Cài đặt danh mục</div>
                <div class="dash-muted mt-1">Bật/tắt danh mục & cấu hình ngưỡng điểm.</div>
            </div>
        </a>
    </div>

    <div class="col-12 col-md-6 col-lg-4">
        <a class="text-decoration-none" href="/admin/cai-dat-cau-hoi">
            <div class="card dash-card p-3">
                <div class="dash-icon"><i class="ti ti-question-mark"></i></div>
                <div class="fw-semibold">Cài đặt câu hỏi</div>
                <div class="dash-muted mt-1">Cập nhật câu hỏi, ảnh và thêm audio cho câu hỏi.</div>
            </div>
        </a>
    </div>

    <div class="col-12 col-md-6 col-lg-4">
        <a class="text-decoration-none" href="/admin/student-overview">
            <div class="card dash-card p-3">
                <div class="dash-icon"><i class="ti ti-user"></i></div>
                <div class="fw-semibold">Danh sách học viên</div>
                <div class="dash-muted mt-1">Xem danh sách + biểu đồ kết quả kiểm tra.</div>
            </div>
        </a>
    </div>
</div>

<div class="row g-3 mt-1">
    <div class="col-12 col-lg-8">
        <div class="card p-3">
            <div class="d-flex align-items-center justify-content-between mb-2 gap-2 flex-wrap">
                <div>
                    <div class="fw-bold fs-5">Lớp x Danh mục câu hỏi</div>
                    <div class="text-muted small">
                        Hiển thị % theo danh mục cho từng lớp học.
                    </div>
                </div>
            </div>
            <div id="courseCategoryChart" style="width:100%; height:460px;"></div>
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="card p-3 h-100">
            <div class="fw-bold fs-5 mb-2">Top 10 cơ sở có học viên làm bài test nhiều</div>
            <div class="text-muted small mb-3">
                Đếm distinct học viên đã có bài test hoàn thành.
            </div>
            <div class="table-responsive">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="bg-success text-white">
                        <tr>
                            <th class="text-center" style="width:70px;">STT</th>
                            <th>Tên cơ sở</th>
                            <th class="text-center" style="width:160px;">Số học viên</th>
                        </tr>
                    </thead>
                    <tbody id="topBranchesTableBody">
                        <tr>
                            <td colspan="4" class="text-center text-muted py-4">Đang tải dữ liệu...</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/echarts/dist/echarts.min.js"></script>

@section Scripts {
    <script>
        window.dashboardConfig = {
            courseCategoryUrl: "/admin/api/dashboard/course-category",
            topBranchesUrl: "/admin/api/dashboard/top-branches?top=10"
        };
    </script>
    <script src="~/js/DashboardJs.js" asp-append-version="true"></script>
}

