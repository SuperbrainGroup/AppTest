@{
    ViewData["Title"] = "Trang chủ";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<style>
    #radarChartResult {
        width: 600px; /* Give it an explicit width */
        height: 450px; /* Give it an explicit height */
        margin: 0 auto;
    }

    #barChartResult {
        width: 600px; /* Give it an explicit width */
        height: 450px; /* Give it an explicit height */
        margin: 0 auto;
    }

    #radarChart {
        width: 600px; /* Give it an explicit width */
        height: 450px; /* Give it an explicit height */
        margin: 0 auto;
    }

    #columnChart {
        width: 600px; /* Give it an explicit width */
        height: 450px; /* Give it an explicit height */
        margin: 0 auto;
    }

    .scroll-box {
        width: 75%;
        height: calc(100vh - 200px);
        background: white;
        border: 1px solid #ccc;
        padding: 20px;
        margin-top: 20px; 
        margin-bottom: 20px; 
        overflow: hidden;
        box-shadow: 2px 4px 8px 4px #51a34755;
        box-sizing: border-box;
    }

    .table-wrapper {
        max-height: calc(100vh - 250px); 
        overflow-y: auto;
        scrollbar-width: thin;
        overscroll-behavior-x: initial;
        scroll-behavior: smooth;
    }

    .scrollbar-width-none {
        scrollbar-width: none;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead th {
        position: sticky;
        top: 0;
        background: #198754; /* Bootstrap success */
        color: white;
        z-index: 1;
    }

    tbody tr:nth-child(even) {
        background-color: #f9f9f9;
    }

    th, td {
        padding: 0.75rem 0.9rem !important;
        text-align: left;
        white-space: nowrap;
        vertical-align: middle;
    }

    .box-dethi {
        margin: 0 auto;
        width: 100%;
        background: white;
        border: 1px solid #e5e7eb;
        padding: 12px;
        overflow: hidden;
        box-shadow: 0 8px 18px rgba(15, 23, 42, 0.06);
        box-sizing: border-box;
        border-radius: 12px;
    }

    .student-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 14px;
    }

    .student-toolbar .search-wrap {
        flex: 0 1 auto;
        min-width: 200px;
        max-width: 300px;
    }

    .student-toolbar .count-wrap {
        font-weight: 600;
        color: #198754;
        display: flex;
        align-items: center;
        gap: 6px;
        white-space: nowrap;
    }

    .table-shell {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        box-shadow: 0 10px 26px rgba(15, 23, 42, 0.05);
        overflow: hidden;
    }

    .table-responsive {
        max-height: calc(100vh - 200px); 
        overflow: auto;
    }

    .action-buttons .btn {
        white-space: nowrap;
    }

    .action-buttons {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        flex-wrap: wrap;
    }

    .print-a4 {
        width: min(100%, 210mm);
        margin: 0 auto;
        padding: 10mm 12mm;
        box-sizing: border-box;
        background: #fff;
    }

    .report-preview {
        background:
            radial-gradient(circle at top right, rgba(49, 90, 138, 0.08), transparent 24%),
            linear-gradient(180deg, #ffffff 0%, #f7f9fc 100%);
        border: 1px solid #d8e0ea;
        border-radius: 18px;
        padding: 16px;
    }

    .report-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 18px;
        padding-bottom: 14px;
        margin-bottom: 14px;
        border-bottom: 2px solid #183153;
    }

    .report-brand {
        max-width: 68%;
    }

    .report-eyebrow {
        margin-bottom: 4px;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 1.8px;
        text-transform: uppercase;
        color: #315a8a;
    }

    .report-title {
        margin: 0 0 6px 0;
        font-size: clamp(1.6rem, 2.3vw, 2.15rem);
        line-height: 1.08;
        font-weight: 900;
        letter-spacing: 0.02em;
        text-transform: uppercase;
        color: #132238;
    }

    .report-subtitle {
        margin: 0;
        max-width: 680px;
        font-size: 0.98rem;
        line-height: 1.6;
        color: #526074;
    }

    .report-meta {
        min-width: 220px;
        border: 1px solid #d7deea;
        border-radius: 14px;
        background: rgba(248, 250, 252, 0.92);
        padding: 12px 14px;
    }

    .report-meta-row + .report-meta-row {
        margin-top: 10px;
        padding-top: 10px;
        border-top: 1px dashed #cbd5e1;
    }

    .report-meta-label {
        margin-bottom: 4px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #64748b;
    }

    .report-meta-value {
        font-size: 0.98rem;
        font-weight: 800;
        color: #132238;
        line-height: 1.4;
    }

    .report-section {
        margin-top: 16px;
    }

    .report-section-title {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 10px;
        font-size: 12px;
        font-weight: 800;
        letter-spacing: 1.1px;
        text-transform: uppercase;
        color: #183153;
    }

    .report-section-title::before {
        content: "";
        width: 22px;
        height: 2px;
        background: #315a8a;
        flex: 0 0 auto;
    }

    .student-summary {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 12px;
    }

    .student-card {
        min-height: 82px;
        border: 1px solid #d7deea;
        border-radius: 14px;
        background: rgba(248, 250, 252, 0.92);
        padding: 12px 14px;
    }

    .student-card-label {
        margin-bottom: 6px;
        font-size: 11px;
        font-weight: 700;
        letter-spacing: 1px;
        text-transform: uppercase;
        color: #64748b;
    }

    .student-card-value {
        font-size: 1rem;
        line-height: 1.45;
        font-weight: 800;
        color: #16253b;
        word-break: break-word;
    }

    .report-note {
        border: 1px solid #d7deea;
        border-radius: 14px;
        background: rgba(252, 253, 255, 0.98);
        padding: 14px 16px;
    }

    .report-note p {
        margin: 0 0 8px 0;
        font-size: 0.97rem;
        line-height: 1.75;
        color: #253247;
    }

    .report-note p:last-child {
        margin-bottom: 0;
    }

    .report-note i {
        color: #315a8a;
    }

    .result-table-shell {
        border: 1px solid #d7deea;
        border-radius: 14px;
        background: #fff;
        overflow: hidden;
    }

    .report-table {
        width: 100%;
        min-width: 100%;
        margin-bottom: 0;
    }

    .report-table thead th {
        position: static;
        background: #183153;
        color: #fff;
        text-align: center;
        font-size: 0.9rem;
        font-weight: 700;
        white-space: nowrap;
    }

    .report-table tbody td {
        white-space: normal;
        font-size: 0.94rem;
        color: #243244;
        border-color: #d7deea;
    }

    .report-table tbody tr:nth-child(even) {
        background: #f8fafc;
    }

    .chart-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 14px;
    }

    .chart-panel {
        border: 1px solid #d7deea;
        border-radius: 16px;
        background: #fff;
        padding: 14px;
    }

    .chart-panel-title {
        margin-bottom: 10px;
        font-size: 11px;
        font-weight: 800;
        letter-spacing: 0.9px;
        text-transform: uppercase;
        color: #183153;
    }

    .chart-canvas {
        width: 100% !important;
        height: 410px !important;
        margin: 0 auto;
    }

    .report-footer {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 14px;
        margin-top: 18px;
        padding-top: 14px;
        border-top: 1px solid #d7deea;
    }

    .report-footer-note {
        font-size: 0.9rem;
        line-height: 1.65;
        color: #64748b;
    }

    .report-signature {
        min-width: 200px;
        text-align: center;
    }

    .report-signature-title {
        margin-bottom: 58px;
        font-size: 0.9rem;
        font-weight: 700;
        color: #1f2937;
    }

    .report-signature-name {
        border-top: 1px solid #c9d4e2;
        padding-top: 7px;
        font-size: 0.92rem;
        font-weight: 800;
        color: #132238;
    }

    @@media (max-width: 767.98px) {
        .student-toolbar .search-wrap {
            max-width: none;
            width: 100%;
        }

        .table-responsive {
            max-height: none;
        }

        table {
            min-width: 980px;
        }

        .print-a4 {
            padding: 0;
        }

        .report-preview {
            padding: 14px;
            border-radius: 0;
        }

        .report-header,
        .report-footer {
            flex-direction: column;
        }

        .report-brand,
        .report-meta {
            max-width: none;
            width: 100%;
        }

        .student-summary,
        .chart-grid {
            grid-template-columns: 1fr;
        }

        .chart-canvas {
            height: 340px !important;
        }
    }

    @@media print {
        body {
            background: #fff;
        }

        .modal-header, .btn, .pagination, #adminSidebar, .admin-backdrop, .student-toolbar {
            display: none !important;
        }

        .box-dethi {
            border: none;
            box-shadow: none;
        }

        .report-preview {
            border: none;
            border-radius: 0;
            padding: 0;
            background: #fff;
        }
    }

    .date-filters-group {
        display: flex;
        align-items: center;
        gap: 8px;
        flex-wrap: nowrap;
    }

    .date-input-wrapper {
        position: relative;
        display: inline-block;
    }

    .date-input-custom {
        min-width: 140px;
        color: #495057;
        cursor: pointer;
    }

    .date-input-custom::-webkit-calendar-picker-indicator {
        cursor: pointer;
        opacity: 1;
    }

    .date-input-custom::placeholder {
        opacity: 0;
    }

    .date-input-custom:not(.has-value) {
        color: transparent !important;
    }

    .date-input-custom:not(.has-value)::-webkit-datetime-edit {
        visibility: hidden !important;
    }

    .date-input-custom:not(.has-value)::-webkit-datetime-edit-fields-wrapper {
        visibility: hidden !important;
    }

    .date-input-custom.has-value {
        color: #495057 !important;
    }

    .date-input-custom.has-value::-webkit-datetime-edit {
        visibility: visible !important;
    }

    .date-input-wrapper::before {
        content: attr(data-placeholder);
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: #aaa;
        font-style: italic;
        pointer-events: none;
        font-size: 1rem;
    }

    .date-input-wrapper.has-value::before {
        display: none;
    }
</style>
<div class="">
    <div class="student-toolbar">
        <div class="search-wrap">
            <input type="text" id="searchInput" class="form-control" placeholder="Tìm kiếm học viên...">
        </div>
        
        <div class="date-filters-group">
            <div class="d-flex align-items-center gap-1">
                <label for="fromDate" class="mb-0 fw-bold small text-nowrap">Từ ngày:</label>
                <div class="date-input-wrapper" data-placeholder="Chọn ngày">
                    <input type="date" id="fromDate" class="form-control form-control-sm date-input-custom">
                </div>
            </div>

            <div class="d-flex align-items-center gap-1">
                <label for="toDate" class="mb-0 fw-bold small text-nowrap">Đến ngày:</label>
                <div class="date-input-wrapper" data-placeholder="Chọn ngày">
                    <input type="date" id="toDate" class="form-control form-control-sm date-input-custom">
                </div>
            </div>

            <button type="button" id="btnReset" class="btn btn-sm btn-outline-danger" title="Xóa lọc">
                <i class="ti ti-refresh"></i> Làm mới
            </button>

            <button type="button" id="btnExport" class="btn btn-sm btn-outline-success" title="Tải danh sách học viên">
                <i class="ti ti-download"></i> Tải dữ liệu
            </button>
        </div>
        
        <div class="count-wrap">
            <i class="ti ti-filter"></i>
            <span id="counts"></span> học viên
        </div>
    </div>
    <div class="table-shell">
        <div class="table-responsive">
            <table class="table table-striped table-hover mb-0">
        <thead class="bg-success text-white">
            <tr>
                <th class="bg-success text-center">STT</th>
                <th class="bg-success text-center">Mã học viên</th>
                <th class="bg-success">Tên học viên</th>
                <th class="bg-success text-center">Year</th>
                <th class="bg-success">Khóa đang học</th>
                <th class="bg-success text-center">Số lần kiểm tra</th>
                <th class="bg-success text-center">Ngày kiểm tra</th>
                <th class="bg-success"></th>
            </tr>
        </thead>
        <tbody id="studentTable">
            <tr>
                <td colspan="8" class="text-center">Đang tải dữ liệu, vui lòng đợi trong giây lát ...</td>
            </tr>
        </tbody>
            </table>
        </div>
    </div>

    <div class="d-flex justify-content-between mb-3" style="width:100%;">
        <div class="input-group mb-3 w-25">
        </div>
        <nav>
            <ul class="pagination justify-content-center">
                <li class="page-item">
                    <button class="page-link" id="prevPage">
                        <svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 256 256" class="size-3.5" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M208.49,199.51a12,12,0,0,1-17,17l-80-80a12,12,0,0,1,0-17l80-80a12,12,0,0,1,17,17L137,128ZM57,128l71.52-71.51a12,12,0,0,0-17-17l-80,80a12,12,0,0,0,0,17l80,80a12,12,0,0,0,17-17Z"></path></svg>
                        Trước
                    </button>
                </li>
                <li class="page-item disabled"><span class="page-link" id="currentPage">1</span></li>
                <li class="page-item">
                    <button class="page-link" id="nextPage">
                        Sau <svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 256 256" class="size-3.5" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M144.49,136.49l-80,80a12,12,0,0,1-17-17L119,128,47.51,56.49a12,12,0,0,1,17-17l80,80A12,12,0,0,1,144.49,136.49Zm80-17-80-80a12,12,0,1,0-17,17L199,128l-71.52,71.51a12,12,0,0,0,17,17l80-80A12,12,0,0,0,224.49,119.51Z"></path></svg>
                    </button>
                </li>
            </ul>
        </nav>
    </div>
</div>

<div id="student-print-chart-host" class="visually-hidden" style="position:absolute;left:-9999px;top:0;width:600px;height:920px;overflow:hidden;pointer-events:none;" aria-hidden="true">
    <div id="radarChartPrint" style="width:600px;height:450px;"></div>
    <div id="columnChartPrint" style="width:600px;height:450px;"></div>
</div>
<script src="https://cdn.jsdelivr.net/npm/echarts@5.5.0/dist/echarts.min.js"></script>
