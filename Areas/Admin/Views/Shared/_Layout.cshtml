@using AppTest.Helper
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Superbrain | Phần mềm đánh giá năng lực</title>
    <link rel="icon" href="/images/icon-web.png" type="image/gif" sizes="45x45">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AppTest.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/jquery-confirm/3.3.4/jquery-confirm.min.css">
</head>
<body>
    <style>
        .admin-shell {
            min-height: 100vh;
            background: #f7f8fb;
        }

        #adminSidebar {
            width: 265px;
            background: #ffffff;
            border-right: 1px solid rgba(0,0,0,.08);
            padding: 16px 12px;
            position: sticky;
            top: 0;
            height: 100vh;
        }

        .sidebar-brand {
            font-weight: 800;
            font-size: 16px;
            padding: 12px 10px;
            border-radius: 12px;
            background: rgba(25, 135, 84, .08);
            color: #198754;
            margin-bottom: 14px;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 12px;
            color: #1f2937;
            text-decoration: none;
            margin-bottom: 6px;
            font-weight: 600;
        }

        .sidebar-link:hover {
            background: rgba(25, 135, 84, .08);
            color: #198754;
        }

        .sidebar-footer {
            margin-top: auto;
            padding-top: 12px;
        }

        .admin-main {
            flex: 1;
            padding: 18px 22px 60px 22px;
        }

        .admin-backdrop {
            display: none;
        }

        @@media (max-width: 767.98px) {
            /* Trên mobile vẫn giữ sidebar hiện ra để toggle lại được.
               class "collapsed" chỉ thu gọn (không translate ra ngoài màn hình). */
            #adminSidebar {
                position: fixed;
                top: 0;
                left: 0;
                height: 100vh;
                width: min(82vw, 300px);
                transform: none;
                transition: width 0.25s ease, padding 0.25s ease;
                z-index: 1045;
                box-shadow: 0 10px 30px rgba(0,0,0,.12);
            }

            #adminSidebar.collapsed {
                width: 84px;
                padding: 16px 10px;
                transform: none;
            }

            .admin-backdrop {
                display: none;
            }

            .admin-main {
                padding: 16px 14px 48px 14px;
            }
        }
    </style>

    <div class="d-flex admin-shell">
        <nav id="adminSidebar" class="d-flex flex-column">
            <div class="sidebar-brand d-flex justify-content-between align-items-center">
                <span class="sidebar-text fw-bold">AppTest Admin</span>
                <button id="sidebarToggle" class="btn btn-sm btn-outline-secondary ms-2" type="button" aria-label="Toggle sidebar">
                    <i class="ti ti-menu-2"></i>
                </button>
            </div>
            <a class="sidebar-link" href="/admin">
                <i class="ti ti-dashboard" aria-hidden="true"></i>
                <span class="sidebar-text">Dashboard</span>
            </a>
            <a class="sidebar-link" href="/admin/cai-dat-danh-muc">
                <i class="ti ti-list-details" aria-hidden="true"></i>
                <span class="sidebar-text">Cài đặt danh mục</span>
            </a>
            <a class="sidebar-link" href="/admin/cai-dat-cau-hoi">
                <i class="ti ti-question-mark" aria-hidden="true"></i>
                <span class="sidebar-text">Cài đặt câu hỏi</span>
            </a>
            <a class="sidebar-link" href="/admin/student-overview">
                <i class="ti ti-user" aria-hidden="true"></i>
                <span class="sidebar-text">Danh sách học viên</span>
            </a>

            <div class="sidebar-footer mt-auto">
                <a class="btn btn-light w-100" href="javascript:signout();">@await Component.InvokeAsync("UserInfo")</a>
            </div>
        </nav>

        <div class="admin-backdrop d-md-none" id="sidebarBackdrop" aria-hidden="true"></div>

        <main class="admin-main flex-grow-1">
            @RenderBody()
        </main>
    </div>
    <script>
        // Sidebar toggle for mobile
        document.addEventListener('DOMContentLoaded', function () {
            var sidebar = document.getElementById('adminSidebar');
            var toggle = document.getElementById('sidebarToggle');
            var backdrop = document.getElementById('sidebarBackdrop');
            if (toggle) {
                toggle.addEventListener('click', function () {
                    sidebar.classList.toggle('collapsed');
                    // Không dùng backdrop kiểu "drawer" nữa (tránh trường hợp sidebar biến mất).
                    if (backdrop) backdrop.classList.remove('show');
                });
            }
            if (backdrop) {
                backdrop.addEventListener('click', function () {
                    sidebar.classList.remove('collapsed');
                    backdrop.classList.remove('show');
                });
            }
        });
    </script>
    @await Html.PartialAsync("_ChangePassword")
    @await Html.PartialAsync("_Notification")
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jquery-confirm/3.3.4/jquery-confirm.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
