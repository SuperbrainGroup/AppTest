@{
    ViewData["Title"] = "Index";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<style>
    .teacher-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 14px;
    }

    .teacher-toolbar .search-wrap {
        flex: 1 1 280px;
        max-width: 420px;
    }

    .table-shell {
        background: #fff;
        border: 1px solid #e5e7eb;
        border-radius: 14px;
        box-shadow: 0 10px 26px rgba(15, 23, 42, 0.05);
        overflow: hidden;
    }

    .table-responsive {
        max-height: calc(100vh - 300px);
        overflow: auto;
    }

    th, td {
        padding: 0.75rem 0.9rem !important;
        white-space: nowrap;
        vertical-align: middle;
    }

    @@media (max-width: 767.98px) {
        .teacher-toolbar .search-wrap {
            max-width: none;
            width: 100%;
        }

        .table-responsive {
            max-height: none;
        }

        table {
            min-width: 900px;
        }
    }
</style>

<div class="teacher-toolbar">
    <div class="search-wrap">
        <input type="text" id="searchInput" class="form-control" placeholder="Tìm kiếm học viên...">
    </div>
</div>
<div class="table-shell">
    <div class="table-responsive">
        <table class="table table-bordered table-hover mb-0">
    <thead class="bg-success text-white">
        <tr>
            <th class="text-center">ID</th>
            <th>Họ và Tên</th>
            <th>Email</th>
            <th class="text-center">Số điện thoại</th>
            <th class="text-center">Trạng thái</th>
            <th class="text-center">Số lần đã test</th>
            <th class="text-end ms-3">Thao tác</th>
        </tr>
    </thead>
    <tbody id="studentTable">
        <tr>
            <td colspan="7" class="text-center">Nhấn "Tải danh sách" để hiển thị dữ liệu</td>
        </tr>
    </tbody>
        </table>
    </div>
</div>

<div class="d-flex justify-content-between mb-3">
    <div class="input-group mb-3 w-25">
        <span class="input-group-text" id="basic-addon1">
            <svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 256 256" class="h-5 w-5 text-gray-500" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M208,32H184V24a8,8,0,0,0-16,0v8H88V24a8,8,0,0,0-16,0v8H48A16,16,0,0,0,32,48V208a16,16,0,0,0,16,16H208a16,16,0,0,0,16-16V48A16,16,0,0,0,208,32ZM72,48v8a8,8,0,0,0,16,0V48h80v8a8,8,0,0,0,16,0V48h24V80H48V48ZM208,208H48V96H208V208Z"></path></svg>
             rows per page
        </span>
        <select id="limitSelect" class="form-select form-select-sm w-25" aria-label=".form-select-sm example">
            <option value="10">10 học viên</option>
            <option value="25">25 học viên</option>
            <option value="50">50 học viên</option>
            <option value="100">100 học viên</option>
        </select>
    </div>
    <nav>
        <ul class="pagination justify-content-center">
            <li class="page-item">
                <button class="page-link" id="prevPage">
                    <svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 256 256" class="size-3.5" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M208.49,199.51a12,12,0,0,1-17,17l-80-80a12,12,0,0,1,0-17l80-80a12,12,0,0,1,17,17L137,128ZM57,128l71.52-71.51a12,12,0,0,0-17-17l-80,80a12,12,0,0,0,0,17l80,80a12,12,0,0,0,17-17Z"></path></svg>
                    Trước
                </button>
            </li>
            <li class="page-item disabled"><span class="page-link" id="currentPage">1</span></li>
            <li class="page-item">
                <button class="page-link" id="nextPage">
                Sau <svg stroke="currentColor" fill="currentColor" stroke-width="0" viewBox="0 0 256 256" class="size-3.5" height="1em" width="1em" xmlns="http://www.w3.org/2000/svg"><path d="M144.49,136.49l-80,80a12,12,0,0,1-17-17L119,128,47.51,56.49a12,12,0,0,1,17-17l80,80A12,12,0,0,1,144.49,136.49Zm80-17-80-80a12,12,0,1,0-17,17L199,128l-71.52,71.51a12,12,0,0,0,17,17l80-80A12,12,0,0,0,224.49,119.51Z"></path></svg>
                </button>
            </li>
        </ul>
    </nav>
</div>
@section Scripts {
    <script src="~/js/TestResult.js"></script>
}
