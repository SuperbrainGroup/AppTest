@{
    ViewData["Title"] = "ResultDetail";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<input type="hidden" name="userId" id="userId" value="@TempData["userId"]" />

<style>
    .teacher-page-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        margin-bottom: 16px;
    }

    .teacher-page-header h4 {
        margin: 0;
        font-weight: 700;
    }

    .info-card .card-header {
        font-weight: 700;
        background: #f8fafc;
    }

    .info-card .form-control {
        background: #f8fafc;
        border-color: #e5e7eb;
    }

    .profile-image {
        width: 110px;
        height: 110px;
        object-fit: cover;
        border: 3px solid #e5e7eb;
    }

    .result-card .card-header {
        font-weight: 700;
        background: #f0fdf4;
        color: #166534;
    }

    #radar-chart {
        min-height: 320px;
    }
</style>

<div class="teacher-page-header">
    <div>
        <h4>Chi tiết kết quả học viên</h4>
        <div class="text-muted">Theo dõi thông tin và kết quả kiểm tra gần nhất</div>
    </div>
</div>

<div class="row g-4">
    <div class="col-xl-4">
        <!-- Profile picture card-->
        <div class="card mb-4 mb-xl-0 info-card shadow-sm">
            <div class="card-header">Thông tin học viên</div>
            <div class="card-body text-center">
                <!-- Profile picture image-->
                <img class="img-account-profile rounded-circle mb-2 profile-image" id="imgprofile" src="https://demos.wrappixel.com/premium-admin-templates/react/elite-react/dark/static/media/user5.847ea5a9e28e437d4624.jpg" alt="">
                <div class="mb-3 text-start">
                    <label class="small mb-1" for="inputname">Họ tên</label>
                    <input class="form-control" id="inputname" type="text" placeholder="Enter your username" value="Họ tên">
                </div>

                <!-- Profile picture upload button-->
                <div class="row gx-3 mb-3">
                    <!-- Form Group (phone number)-->
                    <div class="text-start col-md-6">
                        <label class="small mb-1" for="inputPhone">Mã học viên</label>
                        <input class="form-control" id="inputMaHS" type="tel" placeholder="Enter your phone number" value="555-123-4567">
                    </div>
                    <!-- Form Group (birthday)-->
                    <div class="text-start col-md-6">
                        <label class="small mb-1" for="inputUsername">Tên đăng nhập</label>
                        <input class="form-control" id="inputUsername" type="text" name="username" placeholder="Enter your birthday" value="06/10/1988">
                    </div>
                </div>
                <div class="mb-3 text-start">
                    <label class="small mb-1" for="inputEmailAddress">Email</label>
                    <input class="form-control" id="inputEmailAddress" type="email" placeholder="Enter your email address" value="name@example.com">
                </div>
                <div class="mb-3 text-start">
                    <label class="small mb-1" for="inputPhone">Số điện thoại</label>
                    <input class="form-control" id="inputPhone" type="tel" placeholder="Enter your phone number" value="555-123-4567">
                </div>
            </div>
        </div>
    </div>
    <div class="col-xl-8">
        <!-- Account details card-->
        <div class="card mb-4 result-card shadow-sm">
            <div class="card-header">Kết quả kiểm tra</div>
            <div class="card-body">
                <div id="radar-chart"></div>
                <div id="resultTest"></div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/TestResultDetail.js"></script>
}


