@{
    ViewData["Title"] = "Trang chủ";
}
<style>
    .main-background {
        height: calc(100vh - 70px);
        width: 100%;
        margin: 0; 
        padding: 0;
        overflow: hidden;
        display: flex; 
        justify-content: center; 
        align-items: center;
        background-color: transparent; 
    }

    .content-box {
        width: 90vw; 
        height: auto; 
        aspect-ratio: 3/4; 
        max-width: 500px; 
        max-height: 80vh;
        padding: 20px;
        
        background-image: url('/images/nen.png');
        background-size: contain; 
        background-position: center;
        background-repeat: no-repeat;
        
        filter: drop-shadow(4px 8px 15px rgba(0, 0, 0, 0.15));
        
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    .buddy-img {
        max-width: 70%; 
        height: auto;
        margin-bottom: 15px; 
        border-radius: 20px; 
        animation: float-buddy 3s ease-in-out infinite; 
    }

    @@keyframes float-buddy {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-10px); } 
        100% { transform: translateY(0px); }
    }

    .btn-start-quiz-img {
        background-image: url('/images/nut.png');
        background-size: 100% 100%;
        background-repeat: no-repeat;
        background-color: transparent;
        width: 240px; 
        height: 60px;
        border: none;
        transition: transform 0.2s ease, filter 0.2s ease;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        color: black !important; 
        font-size: 1.2rem; 
        font-weight: 800; 
        text-decoration: none; 
    }
    
    @@media (min-width: 768px) {
        .content-box { width: 95vw; max-width: 1000px; padding: 40px 20px; aspect-ratio: unset; height: calc(100vh - 120px); background-size: 100% 100%; }
        .buddy-img { max-width: 320px; }
        .btn-start-quiz-img { width: 300px; height: 75px; font-size: 1.6rem; }
    }
</style>

<div class="d-flex align-items-center mb-2 sticky-top" style="background:#51a347;padding:10px 10px;z-index:1; min-height: 60px;">
    <div class="flex-shrink-0 d-flex align-items-center">
        <a href="/"><img src="/images/logo.png" alt="Logo" class="img-fluid me-2" style="height: 30px;"></a>
        <img src="/images/avatar.png" alt="Avatar" class="img-fluid rounded-circle border border-white border-2" style="width: 45px; height: 45px;">
    </div>

    <div class="flex-grow-1 overflow-hidden text-center"> 
        <div style="line-height: 1.3; padding-bottom: 2px;">
            <h5 class="mb-0 text-white" style="font-size: 0.85rem;">
                👋 Xin chào, 
                <b class="d-block text-truncate" style="font-size: 0.95rem;">@TempData["name"]</b>
            </h5>
            <p class="mb-0 text-white" style="font-size: 0.75rem; opacity: 0.9;">let's play quiz</p>
        </div>
    </div>

    <div class="flex-shrink-0 mb-1">
        <a href="javascript:signout()" class="btn btn-sm btn-rounded" style="background:#6cbf45;color:#fff;border:1px solid #fff; font-size: 0.7rem; padding: 4px 8px;">
            <span class="d-none d-sm-inline">Đăng xuất</span> <i class="ti ti-logout"></i>
        </a>
    </div>
</div>

<div class="main-background">
    <div class="content-box">
        <img src="/images/Buddy-start.png" alt="Buddy Chào mừng" class="buddy-img" />
        <a class="btn-start-quiz-img" href="/bai-kiem-tra">Bắt đầu làm bài</a>
    </div>
</div>
@section Scripts {
    <script src="~/js/DashboardJs.js"></script>
}
