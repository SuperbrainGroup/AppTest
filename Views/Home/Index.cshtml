@{
    ViewData["Title"] = "Trang chủ";
}
<style>
    .scroll-box {
        width: 60%;
        height: calc(100vh - 200px);
        background: white;
        border: 1px solid #ccc;
        padding: 20px;
        margin-top: 50px;
        overflow: auto;
        scroll-behavior:smooth;scrollbar-width:none;
        box-shadow: 2px 4px 8px 4px #51a34755;
        box-sizing: border-box;
    }

    .table-wrapper {
        max-height: calc(100vh - 360px); /* chiều cao phần tbody có thể scroll */
        overflow-y: auto;
        scrollbar-width: none;
    }

    .scrollbar-width-none {
        scrollbar-width: none;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead th {
        position: sticky;
        top: 0;
        background: #198754; /* Bootstrap success */
        color: white;
        z-index: 1;
    }

    tbody tr:nth-child(even) {
        background-color: #f9f9f9;
    }

    th, td {
        padding: 1.2rem !important;
        text-align: left;
        white-space: nowrap;
    }

    .box-dethi {
        margin: 0 auto;
        width: 100%;
        background: white;
        border: 1px solid #ccc;
        padding: 20px;
        overflow: hidden;
        box-shadow: 1px 1px 2px 1px #51a34755;
        box-sizing: border-box;
    }
</style>

<div class="d-flex align-items-center mb-2 sticky-top" style="background:#51a347;padding:10px 30px;z-index:1;">
    <div class="flex-shrink-0">
        <a href="/"><img src="/images/logo.png" alt="Sơn Hà Lê" class="img-fluid ms-5 me-3" style="height: 40px;"></a>
        <img src="/images/avatar.png" alt="Sơn Hà Lê" class="img-fluid rounded-circle border border-white border-3" style="width: 40px;">
    </div>
    <div class="flex-grow-1 ms-3">
        <div>
            <h5 class="mb-0 fs-6 me-2 text-white">👋 Xin chào, <b>@TempData["name"]</b></h5>
            <p class="mb-0 text-white"> let's play quiz</p>
        </div>
    </div>
    <div class="flex-grow-1 ms-5 text-end">
        <a href="javascript:signout()" class="btn btn-sm btn-rounded ms-3" style="background:#6cbf45;color:#fff;border:1px solid #fff;">
            Đăng xuất <i class="ti ti-logout"></i>
        </a>
    </div>
</div>
<div style=" height: 100%;margin: auto; padding: 0;overflow: hidden;display: flex; justify-content: center; align-items: center;background-color: #f0f0f000; ">
    <div class="scroll-box text-center">
        <p class="mt-3">Ứng dụng trắc nghiệm đánh giá năng lực cho trẻ, giúp phát triển các kỹ năng quan trọng để đánh giá sự tập trung ghi nhớ và phản xạ. Các bài kiểm tra được thiết kế để thúc đẩy sự phát triển tư duy và khả năng ghi nhớ của trẻ một cách hiệu quả và thú vị.</p>
        <a class="btn btn-lg btn-success mt-3 rounded-2 btn-animation" href="/bai-kiem-tra">
            Bắt đầu làm bài
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="icon icon-tabler icons-tabler-outline icon-tabler-arrow-narrow-right-dashed"><path stroke="none" d="M0 0h24v24H0z" fill="none" /><path d="M5 12h.5m3 0h1.5m3 0h6" /><path d="M15 16l4 -4" /><path d="M15 8l4 4" /></svg>
        </a>
    </div>
</div>
@section Scripts {
    <script src="~/js/DashboardJs.js"></script>
}
