@{
    ViewData["Title"] = "Trang chủ";
}
<style>
    /* 1. Vùng bao ngoài (Chỉ để căn giữa, không có nền) */
    .main-background {
        height: calc(100vh - 80px); 
        width: 100%;
        margin: 0; 
        padding: 0;
        overflow: hidden;
        display: flex; 
        justify-content: center; 
        align-items: center;
        background-color: transparent; 
    }

    /* 2. Khung ảnh nền */
    .content-box {
        width: 95vw; 
        height: calc(100vh - 120px); 
        max-width: 1000px; 
        padding: 40px 20px;
        
        /* ẢNH NỀN */
        background-image: url('/images/nen.png');
        background-size: 100% 100%; 
        background-position: center;
        background-repeat: no-repeat;
        
        filter: drop-shadow(4px 8px 15px rgba(0, 0, 0, 0.15));
        
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    /* 3. Hình nhân vật Buddy */
    .buddy-img {
        max-width: 320px; 
        height: auto;
        margin-bottom: 25px; 
        border-radius: 20px; 
        /* Lệnh gọi animation */
        animation: float-buddy 3s ease-in-out infinite; 
    }

    @@keyframes float-buddy {
        0% { transform: translateY(0px); }
        50% { transform: translateY(-15px); } 
        100% { transform: translateY(0px); }
    }

    /* 4. CSS cho nút ảnh (Đã thêm định dạng chữ) */
    .btn-start-quiz-img {
        background-image: url('/images/nut.png');
        background-size: 100% 100%;
        background-repeat: no-repeat;
        background-color: transparent;
        width: 300px; 
        height: 75px;
        border: none;
        transition: transform 0.2s ease, filter 0.2s ease;
        cursor: pointer;

        /* Chữ cho nút */
        display: flex;
        align-items: center;
        justify-content: center;
        color: black !important; 
        font-size: 1.6rem; 
        font-weight: 800; 
        text-decoration: none; 
        letter-spacing: 1px; 
    }
    
    .btn-start-quiz-img:hover {
        transform: scale(1.05); 
        filter: brightness(1.1); 
        color: white; 
    }
    
    /* Responsive cho màn hình điện thoại */
    @@media (max-width: 768px) {
        .content-box { width: 95%; min-height: 350px; padding: 30px 15px; }
        .buddy-img { max-width: 140px; margin-bottom: 20px; }
        .btn-start-quiz-img { width: 220px; height: 60px; }
    }
</style>

<div class="d-flex align-items-center mb-2 sticky-top" style="background:#51a347;padding:10px 30px;z-index:1;">
    <div class="flex-shrink-0">
        <a href="/"><img src="/images/logo.png" alt="Sơn Hà Lê" class="img-fluid ms-5 me-3" style="height: 40px;"></a>
        <img src="/images/avatar.png" alt="Sơn Hà Lê" class="img-fluid rounded-circle border border-white border-3" style="width: 40px;">
    </div>
    <div class="flex-grow-1 ms-3">
        <div>
            <h5 class="mb-0 fs-6 me-2 text-white">👋 Xin chào, <b>@TempData["name"]</b></h5>
            <p class="mb-0 text-white"> let's play quiz</p>
        </div>
    </div>
    <div class="flex-grow-1 ms-5 text-end">
        <a href="javascript:signout()" class="btn btn-sm btn-rounded ms-3" style="background:#6cbf45;color:#fff;border:1px solid #fff;">
            Đăng xuất <i class="ti ti-logout"></i>
        </a>
    </div>
</div>
<div class="main-background">
    <div class="content-box">
        
        <img src="/images/Buddy-start.png" alt="Buddy Chào mừng" class="buddy-img" />

        <a class="btn-start-quiz-img" href="/bai-kiem-tra">Bắt đầu làm bài</a>
        
    </div>
</div>
@section Scripts {
    <script src="~/js/DashboardJs.js"></script>
}
