@{
    ViewData["Title"] = "TestPage";
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<style>
    .scroll-box {
        width: 60%;
        max-width: 960px;
        height: calc(100vh - 140px); 
        background: white;
        border: 1px solid #ccc;
        padding: 12px 20px 20px 20px;
        
        margin: 0 !important; 
        
        overflow: auto;
        scroll-behavior: smooth;
        scrollbar-width: none;
        box-shadow: 2px 4px 8px 4px #51a34755;
        box-sizing: border-box;
        border-radius: 12px;
    }

    .table-wrapper {
        max-height: calc(100vh - 360px); /* chiều cao phần tbody có thể scroll */
        overflow-y: auto;
        scrollbar-width: none;
    }

    .scrollbar-width-none {
        scrollbar-width: none;
    }

    table {
        width: 100%;
        border-collapse: collapse;
    }

    thead th {
        position: sticky;
        top: 0;
        background: #198754; /* Bootstrap success */
        color: white;
        z-index: 1;
    }

    tbody tr:nth-child(even) {
        background-color: #f9f9f9;
    }

    th, td {
        padding: 1.2rem !important;
        text-align: left;
        white-space: nowrap;
    }

    .box-dethi {
        margin: 0 auto;
        width: 100%;
        background: white;
        border-radius: 10px;
        padding: 16px 20px 20px 20px;
        box-sizing: border-box;
    }

    .answers-grid {
        display: grid;
        grid-template-columns: repeat(2, auto); 
        gap: 25px; /* Tăng khoảng cách cho thoáng */
        margin-top: 15px;
        justify-content: center; 
    }

    .answers-grid:has(.answer-item:nth-child(1)) .answer-item:has(img) .answer-text {
        font-size: 1.5rem !important;
    }


    @@media (max-width: 768px) {
        .scroll-box {
            width: 100%;
            height: calc(100vh - 120px);
        }


        .answers-grid {
            display: grid;
            gap: 15px; 
            justify-content: center;
            justify-items: center;
            padding: 0 6px;
            width: 100%;
            box-sizing: border-box;
        }


        .answers-grid:has(.answer-item:nth-child(3)) {
            grid-template-columns: repeat(2, 1fr);
            width: 100%;
        }

        .answers-grid:not(:has(.answer-item:nth-child(3))) {
            grid-template-columns: 1fr;
        }

        .answer-item:first-child:nth-last-child(2),
        .answer-item:first-child:nth-last-child(2) ~ .answer-item {
            width: 60vw !important;
            max-width: 280px !important;
            aspect-ratio: 1 / 1 !important;
        }


        .answer-item:first-child:nth-last-child(4),
        .answer-item:first-child:nth-last-child(4) ~ .answer-item {
            width: 100%;
            max-width: 40vw;
            aspect-ratio: 1 / 1 !important;
        }


        #quiz-container:has(#questionImage:not(.d-none)) .answers-grid:has(.answer-item:nth-child(3)) {
            gap: 10px; 
        }

        #quiz-container:has(#questionImage:not(.d-none)) .answer-item:first-child:nth-last-child(4),
        #quiz-container:has(#questionImage:not(.d-none)) .answer-item:first-child:nth-last-child(4) ~ .answer-item {
            width: 44vw !important;
            height: auto !important;
            aspect-ratio: 1.5 / 1 !important; 
            min-width: 0;
            padding: 8px;
        }

        .answers-grid:has(.answer-item:nth-child(3)) .answer-text {
            font-size: 1.6rem !important;
        }

        .answers-grid:has(.answer-item:nth-child(3)) .answer-item:has(img) .answer-text {
            font-size: 1rem !important;
        }

        #questionImage {
            max-height: 35vh !important;
            transition: opacity 0.5s ease !important;
            opacity: 1;
        }

        #questionImage.gif-hidden {
            opacity: 0 !important;
            pointer-events: none;
        }
        .result-bg-box {
            width: 90vw !important;       
            height: 45vh !important;       
            max-height: 450px;             
            
            background-size: 100% 100% !important;
            position: relative;
            left: 50%;
            transform: translateX(-50%);
            
            margin-top: 5vh;               
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .buddy-img-result {
            max-width: 85% !important; 
            height: auto;
            margin-bottom: 5px;
            margin-top: -20px; 
        }

        .btn-custom-img {
            width: 280px !important; 
            height: 65px !important;
            font-size: 1.1rem !important; 
            letter-spacing: 0;
        }

        .result-bg-box .d-flex.flex-wrap {
            gap: 10px !important;
            flex-direction: column; 
            align-items: center;
        }

        #totalTimeLabel {
            font-size: 1.1rem !important;
            margin-bottom: 15px !important;
        }
    }
 
    .answer-item {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        aspect-ratio: 1.65 / 1; 
        
        /* Kích thước khi có 4 đáp án (2x2) */
        width: 50vh; 
        max-width: 50vw; 

        border-radius: 15px;
        border: 1px solid #e2e8f0;
        background: #f9fafb;
        padding: 12px;
        cursor: pointer;
        transition: all 0.25s ease;
        overflow: hidden;
    }

    /* Logic đặc biệt khi CHỈ CÓ 2 ĐÁP ÁN 
       (Tự động phóng to khung hình vuông) */
    .answer-item:first-child:nth-last-child(2),
    .answer-item:first-child:nth-last-child(2) ~ .answer-item {
        width: 100%; 
        max-width: 100%;
    }

    .answer-item:hover {
        background: #ecfdf3;
        border-color: #4ade80;
        box-shadow: 0 8px 20px rgba(0,0,0,0.06);
        transform: translateY(-2px);
    }

    .answer-item.selected {
        background: #00783C !important;
        border-color: #004b26 !important;
        color: #ffffff;
        box-shadow: 0 0 0 4px rgba(22, 163, 74, 0.3);
    }

    #quiz-container:has(#questionImage:not(.d-none)) .answers-grid {
        gap: 12px;
        margin-top: 5px;
    }

    #quiz-container:has(#questionImage:not(.d-none)) .answer-item {
        aspect-ratio: 3.5 / 1; 
        height: 12vh;          
        width: auto;           
        min-width: 250px;
        padding: 8px;
    }

    #quiz-container:has(#questionImage:not(.d-none)) .answer-item:first-child:nth-last-child(2),
    #quiz-container:has(#questionImage:not(.d-none)) .answer-item:first-child:nth-last-child(2) ~ .answer-item {
        width: 40vh;
        height: 12vh;
        aspect-ratio: 3 / 1;
    }

    #quiz-container:has(#questionImage:not(.d-none)) .answer-item img {
        max-height: 90%; 
        width: auto;
    }
    .answer-item img {
        width: 100%;
        height: 100%;
        object-fit: contain; 
        border-radius: 6px;
        margin: 0;
    }

    .answer-text {
        display: block;
        line-height: 1.2;
        word-break: break-word;
        text-align: center;
        font-size: 2.8rem; 
        font-weight: 700;
        color: inherit;
    }

    .answer-item:has(img) .answer-text {
        font-size: 1rem; 
        font-weight: 600;
        margin-bottom: 5px; 
        flex: 0 0 auto;     
    }

    .answer-item:has(img) img {
        flex: 1 1 auto;
        max-height: calc(100% - 30px); 
    }

    .quiz-header-row {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
        flex-wrap: nowrap;
        min-width: 0;
    }

    .quiz-header-left {
        display: flex;
        align-items: center;
        gap: 8px;
        flex: 0 0 auto;
    }

    .quiz-header-actions {
        flex: 0 0 auto;
        white-space: nowrap;
    }

    .timer-div {
        flex: 0 0 auto;
        white-space: nowrap;
    }

    #btnPlayAudio {
        flex: 0 0 auto;
        width: 42px;
        height: 36px;
        padding: 0;
        display: inline-flex;
        align-items: center;
        justify-content: center;
    }

    #question-text {
        display: block;
        margin-top: 8px;
        font-size: 1.5rem;
        font-weight: 600 !important;
        line-height: 1.35;
        color: #000000 !important;
        word-break: break-word;
    }

    @@media (max-width: 768px) {
        #next-btn {
            min-width: 112px;
        }
    }
    /* =========================================
       CSS CHO GIAO DIỆN KẾT THÚC
       ========================================= */
    
    /* 1. Vô hiệu hóa khung trắng của bài thi khi hiện kết quả */
    .scroll-box:has(#result:not(.d-none)) {
        background: transparent !important;
        border: none !important;
        box-shadow: none !important;
        padding: 0 !important;
        overflow: visible !important;
        display: flex !important;
        align-items: center !important;
        justify-content: center !important;
        width: 100% !important;  
        max-width: 1600px !important; 
        height: calc(100vh - 80px) !important; 
    }

    #display-container:has(#result:not(.d-none)) {
        overflow: visible !important;
    }

    /* 3. Khung nền xanh */
    .result-bg-box {
        width: 95vw; 
        max-width: 1000px; /* Chỉnh bề ngang khung hình nền */
        height: calc(100vh - 120px); 
        
        position: relative;
        left: 50%;
        transform: translateX(-50%);
        
        background-image: url('/images/nen.png');
        background-size: 100% 100%;
        background-position: center;
        background-repeat: no-repeat;
        background-color: transparent;
        filter: drop-shadow(4px 8px 15px rgba(0, 0, 0, 0.15));
        
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
    }

    /* 4. Buddy kết thúc (Phóng to theo yêu cầu) */
    .buddy-img-result {
        max-width: 420px; 
        height: auto;
        margin-bottom: 20px;
        animation: float-buddy-result 3s ease-in-out infinite;
    }

    @@keyframes float-buddy-result {
        0%, 100% { transform: translateY(0); }
        50% { transform: translateY(-15px); }
    }

    /* 5. Nút bấm (Căn chỉnh khoảng cách) */
    .btn-custom-img {
        background-image: url('/images/nut.png');
        background-size: 100% 100%;
        background-repeat: no-repeat;
        background-color: transparent;
        width: 320px; 
        height: 75px;
        border: none;
        display: flex;
        align-items: center;
        justify-content: center;
        color: black !important;
        font-size: 1.4rem;
        font-weight: 800;
        text-decoration: none;
        transition: transform 0.2s;
        letter-spacing: 1px; 
    }

    .btn-custom-img:hover {
        transform: scale(1.05);
        filter: brightness(1.1); 
        color: white;
    }

    .main-container-wrapper {
        height: calc(100vh - 80px) !important; 
        display: flex !important;
        justify-content: center !important;
        align-items: center !important;
        background-color: transparent;
        overflow: visible !important; 
    }

    #reviewModal .table thead th, 
    #reviewModal .table-light th { 
        position: sticky;
        top: 0;
        background-color: #198754 !important;
        color: #ffffff !important;
        text-align: center;
        border-color: #146c43 !important;
        z-index: 2;
        font-weight: 700;
        padding: 12px 8px !important;
    }

    #review-table-body td:last-child,
    #review-table-body td:last-child *,
    #review-table-body .text-success,
    #review-table-body .text-danger,
    #review-table-body .text-muted {
        color: #000000 !important; 
        opacity: 1 !important;     
        font-weight: 700 !important;
        text-fill-color: #000000 !important;
        -webkit-text-fill-color: #000000 !important;
    }

    #review-table-body td:nth-child(1),
    #review-table-body td:last-child {
        text-align: center !important;
        vertical-align: middle !important;
    }

    #reviewModal .table thead th:nth-child(1),
    #reviewModal .table thead th:last-child {
        text-align: center !important;
    }
</style>

<div class="d-flex align-items-center mb-2 sticky-top" style="background:#51a347; padding: 10px 10px 2px 10px; z-index:1; min-height: 60px;">
    <div class="flex-shrink-0 d-flex align-items-center">
        <a href="/"><img src="/images/logo.png" alt="Logo" class="img-fluid me-2" style="height: 30px;"></a>
        <img src="/images/avatar.png" alt="Avatar" class="img-fluid rounded-circle border border-white border-2" style="width: 45px; height: 45px;">
    </div>

    <div class="flex-grow-1 overflow-hidden text-center"> 
        <div style="line-height: 1.3; padding-bottom: 2px;">
            <h5 class="mb-0 text-white" style="font-size: 0.85rem;">
                👋 Xin chào, 
                <b class="d-block text-truncate" style="font-size: 0.95rem;">@TempData["name"]</b>
            </h5>
            <p class="mb-0 text-white" style="font-size: 0.75rem; opacity: 0.9;">let's play quiz</p>
        </div>
    </div>

    <div class="flex-shrink-0 align-self-end mb-1 d-flex gap-1">
        <a id="btn-quiz-back" href="/" class="btn btn-sm btn-warning fw-bolder" style="font-size: 0.7rem; padding: 4px 8px;">
            <i class="ti ti-arrow-left"></i> <span class="d-none d-sm-inline">Quay về</span>
        </a>
        <a href="javascript:signout()" class="btn btn-sm btn-rounded" style="background:#6cbf45; color:#fff; border:1px solid #fff; font-size: 0.7rem; padding: 4px 8px;">
             <span class="d-none d-sm-inline">Đăng xuất</span> <i class="ti ti-logout"></i>
        </a>
    </div>
</div>
<div class="main-container-wrapper">
    <div class="scroll-box">
        <div id="header-question" class="mb-3 sticky-top" style="width:100%;border-bottom:1px dashed #dadada; padding-bottom:6px; background:#fff;">
            <div class="quiz-header-row">
                <div class="quiz-header-left">
                    <span class="btn btn-sm btn-success fs-6 timer-div">
                    <svg height="15px" width="15px" version="1.1" id="_x32_" xmlns="http://www.w3.org/2000/svg" xmlns:xlink="http://www.w3.org/1999/xlink" viewBox="0 0 512 512" xml:space="preserve" fill="#ffffff" stroke="#ffffff"><g id="SVGRepo_bgCarrier" stroke-width="0"></g><g id="SVGRepo_tracerCarrier" stroke-linecap="round" stroke-linejoin="round"></g><g id="SVGRepo_iconCarrier"> <style type="text/css"> .st0{fill:#ffffff;} </style> <g> <path class="st0" d="M461.04,280.543c-0.016-108.556-84.38-197.136-191.12-204.324V47.096h-27.848v29.124 C135.349,83.416,50.981,172.002,50.965,280.543c0.016,65.74,31.039,124.076,79.137,161.606l-27.388,46.502L137.487,512 l34.033-44.783c25.776,11.696,54.332,18.374,84.484,18.374c29.362,0,57.227-6.284,82.477-17.403L371.757,512l34.823-23.349 l-26.598-45.071C429.161,406.117,461.024,347.138,461.04,280.543z M261.663,419.506h-10.298h-4.836v17.856 c-37.15-2.212-70.621-17.206-96.446-40.786l13.148-13.143l-7.288-7.286l-13.278,13.282c-24.23-25.242-40.07-58.312-43.254-95.2 h19.735v-21.055H99.091c1.768-37.989,16.865-72.245,40.884-98.548l15.253,15.257l7.287-7.288l-15.392-15.388 c25.718-24.682,59.575-40.605,97.301-43.352v21.935h5.921h10.298h4.836v-22.042c38.203,2.278,72.553,18.036,98.658,42.768 l-15.368,15.364l7.288,7.287l15.298-15.298c23.962,25.916,39.215,59.686,41.456,97.198h-19.948v21.055h19.842 c-2.726,37.373-18.39,70.929-42.669,96.557l-13.254-13.258l-7.286,7.279l13.192,13.192c-25.438,23.53-58.428,38.688-95.101,41.362 v-17.749H261.663z"></path> <path class="st0" d="M81.396,11.401c-40.4,23.39-54.184,75.099-30.776,115.506l146.283-84.722 C173.527,1.786,121.811-12.007,81.396,11.401z"></path> <path class="st0" d="M430.593,11.401c-40.395-23.408-92.112-9.615-115.503,30.784l146.295,84.722 C484.793,86.5,470.991,34.791,430.593,11.401z"></path> <polygon class="st0" points="283.943,190.245 251.719,269.859 199.501,250.803 192.214,270.78 259.499,295.323 259.717,294.731 260.791,295.166 300.541,196.964 "></polygon> </g> </g></svg>
                        <span class="time-left pt-2"><span id="minutes"></span>:<span id="seconds"></span></span>
                    </span>
                    <button type="button" class="btn btn-sm btn-outline-success fs-6 timer-div d-none" id="btnPlayAudio" aria-label="Nghe lại câu hỏi">
                        <i class="ti ti-player-play"></i>
                    </button>
                    <button type="button" class="btn btn-sm btn-outline-success fs-6 timer-div" id="btn-show-gif" aria-label="Xem lại ảnh" title="Xem lại ảnh GIF" style="display: none;">
                        Xem lại ảnh
                    </button>
                </div>
                <div class="quiz-header-actions">
                    <button id="next-btn" style="display: none;" class="btn btn-sm btn-outline-secondary">Bỏ qua <i class="ti ti-arrow-right"></i></button>
                </div>
            </div>
            <span id="question-text" class="text-muted"></span>
            <div class="mt-2">
                <div class="d-flex align-items-center gap-2">
                    <div class="progress flex-grow-1" style="height:6px;">
                        <div id="quizProgressBar" class="progress-bar bg-success" role="progressbar"
                             style="width:0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100"></div>
                    </div>
                    <span id="quizProgressText" class="small text-muted"></span>
                </div>
            </div>
        </div>
        <div id="display-container" style="overflow:auto;scrollbar-width:none;">
            <input type="hidden" id="ageGroup"/>
            <div id="quiz-container" class="text-center">
                <img src="" alt="questionImage" id="questionImage" class="d-none mb-2 questionImage" height="auto" width="auto" 
                            style="max-height: 40vh; width: 100%; object-fit: contain; margin: 0 auto; border-radius: 7px; border-bottom: 1px dashed #dadada; padding-bottom: 5px;"
" />
                <div id="answers-grid" class="answers-grid"></div>
                <div id="status" class="text-center text-sm text-gray-500 min-h-[20px] "></div>
                <audio id="audio-player" class="d-none"></audio>
            </div>
            <div class="text-center d-none" id="result">
                <div class="result-bg-box">
                    
                    <img src="/images/Buddy-end.png" alt="Chúc mừng" class="buddy-img-result" />

                    <p id="totalTimeLabel" class="mb-4 fw-bold fs-5" style="color: black !important;"></p>
                    
                    <div class="d-flex flex-wrap justify-content-center gap-3">
                        <button type="button" id="btn-show-review" class="btn-custom-img" data-bs-toggle="modal" data-bs-target="#reviewModal">
                            Xem lại câu trả lời
                        </button>
                        
                        <button type="button" id="btn-restart" class="btn-custom-img">
                            Làm lại bài kiểm tra
                        </button>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="modal fade" id="reviewModal" tabindex="-1" aria-labelledby="reviewModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="reviewModalLabel">Các câu đã trả lời</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
            </div>
            <div class="modal-body p-0">
                <div class="table-responsive">
                    <table class="table table-sm table-striped mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:48px;">#</th>
                                <th style="width:150px;">Danh mục</th>
                                <th>Câu hỏi</th>
                                <th style="width:100px;">Kết quả</th>
                            </tr>
                        </thead>
                        <tbody id="review-table-body"></tbody>
                    </table>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    <script src="~/js/QuizJs.js"></script>
}
