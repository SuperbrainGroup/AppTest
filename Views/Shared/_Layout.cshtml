<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Superbrain | Phần mềm đánh giá năng lực</title>
    <link href="/images/icon-web.png" rel="icon" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AppTest.styles.css" asp-append-version="true" />
    <style>
        html,body{
            cursor: url(https://cdn.custom-cursor.com/db/18274/32/starter-orange-smile-cursor.png), default !important;
        }
        a:hover,li:hover,button:hover,span.button:hover,input:hover{
                cursor: url(https://cdn.custom-cursor.com/db/18273/32/starter-orange-smile-pointer.png), pointer !important;
        }
    </style>
</head>
<body style="background-image:url('/images/bg.webp');background-size:cover;">
    @RenderBody()
    <div class="toast-container position-fixed top-0 end-0 p-3">
        <div class="toast bg-light" role="alert" aria-live="assertive" aria-atomic="true">
            <div class="toast-header">
                <strong class="me-auto">Thông báo</strong>
                <small>2 seconds ago</small>
            </div>
            <div class="toast-body">
                <span id="notificationText"></span>
            </div>
        </div>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    <script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
